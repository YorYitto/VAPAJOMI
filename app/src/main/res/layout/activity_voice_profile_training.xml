<?xml version="1.0" encoding="utf-8"?>
<!-- activity_voice_profile_training.xml -->
<!-- UBICACIÓN: app/src/main/res/layout/ -->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ENTRENAMIENTO DE VOZ"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#02B126"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/instructionsText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Muestra 1 de 3"
        android:textSize="20sp"
        android:textColor="#000000"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_marginBottom="32dp"
        android:progressTint="#02B126" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Por favor, di la siguiente frase:"
        android:textSize="18sp"
        android:textColor="#000000"
        android:textAlignment="center"
        android:gravity="center"
        android:layout_marginBottom="48dp"
        android:padding="16dp" />

    <Button
        android:id="@+id/recordButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GRABAR MUESTRA 1"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#02B126"
        android:padding="16dp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/skipButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Saltar entrenamiento (no recomendado)"
        android:textSize="14sp"
        android:textColor="#666666"
        android:backgroundTint="#EEEEEE"
        android:padding="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="El entrenamiento de voz permite que solo tú puedas controlar la aplicación"
        android:textSize="12sp"
        android:textColor="#999999"
        android:textAlignment="center"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:padding="16dp" />

</LinearLayout>